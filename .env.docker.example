# Copy this file to .env.docker before running docker compose.

# Local Docker Desktop URLs.
FRONTEND_URL=http://localhost:3000
CLIENT_URL=http://localhost:3000

# External hosted MongoDB connection string.
MONGO_URI=mongodb+srv://USER:PASSWORD@HOST/SANIACLOTHING?retryWrites=true&w=majority

# Auth
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRE=7d

# For initial HTTP-only testing on an IP, keep these values.
# Once your site is served over HTTPS, use COOKIE_SECURE=true and COOKIE_SAME_SITE=none.
COOKIE_SECURE=false
COOKIE_SAME_SITE=lax

# Cloudinary uploads
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Email for password reset
SMTP_HOST=
SMTP_PORT=587
SMTP_SERVICE=
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
